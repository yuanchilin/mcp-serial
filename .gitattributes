# Auto detect text files and normalize to LF
* text=auto

# Shell scripts — keep LF + executable on checkout
*.sh text eol=lf
*.ps1 text eol=lf

# TypeScript / JavaScript
*.ts text
*.js text
*.cts text
*.cjs text
*.mjs text
*.d.ts text

# Web
*.html text
*.css text

# Configuration
*.json text
*.yml text
*.yaml text
*.toml text
*.ini text
.editorconfig text

# Documentation
*.md text
*.txt text

# Git files
.gitignore text
.gitattributes text

# Binary files — keep as-is
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
